# ──────────────────────────────────────────────────────────────────────────────
# ChronoCare AI – Environment Configuration
# Copy this file to .env and fill in values before running docker-compose up.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite – no setup required):
DATABASE_URL=sqlite:///./chronocare.db
# Production (PostgreSQL via Docker Compose – set POSTGRES_PASSWORD below):
# DATABASE_URL=postgresql://chronocare:${POSTGRES_PASSWORD}@db:5432/chronocare

# Required when using Docker Compose with PostgreSQL:
POSTGRES_PASSWORD=change-me-in-production

# ── Redis (optional – app works without it, caching disabled) ─────────────────
REDIS_URL=redis://localhost:6379

# ── API ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# CORS: comma-separated list of allowed frontend origins.
# In production replace with your actual domain, e.g.:
# CORS_ORIGINS=https://chronocare.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Authentication (optional) ─────────────────────────────────────────────────
# Set ENABLE_AUTH=true to require an API key on every request.
ENABLE_AUTH=false
# Comma-separated list of valid API keys when ENABLE_AUTH=true:
API_KEYS=dev-chronocare-2026

# ── ML ────────────────────────────────────────────────────────────────────────
MODELS_DIR=models
NOSHOW_HIGH_RISK_THRESHOLD=0.4

# ── Scheduling weights ────────────────────────────────────────────────────────
ALPHA_WAITING_TIME=0.5
BETA_WORKLOAD_VARIANCE=0.3
GAMMA_SCHEDULE_OVERRUN=0.2
